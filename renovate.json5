{
  extends: [
    "config:best-practices"
  ],
  dependencyDashboard: false,
  enabledManagers: [
    "npm",
    "bun",
    "github-actions",
    "dockerfile"
  ],
  minimumReleaseAge: "3 days",
  lockFileMaintenance: {
    minimumReleaseAge: null,
  },
  vulnerabilityAlerts: {
    minimumReleaseAge: null,
  },
  packageRules: [
    {
      matchUpdateTypes: [
        "minor",
        "patch",
        "digest",
        "pinDigest"
      ],
      groupName: "all minor, patch, and digest updates",
      groupSlug: "all-minor-patch-digest-updates",
    },
    {
      matchManagers: [
        "github-actions"
      ],
      minimumReleaseAge: "7 days"
    },
    {
      matchManagers: [
        "npm",
        "bun"
      ],
      matchFileNames: [
        "apps/**",
        "packages/**",
        "package.json"
      ],
      groupName: "JavaScript/TypeScript dependencies",
      rangeStrategy: "bump"
    }
  ]
}
