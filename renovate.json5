{
  extends: [
    "config:best-practices"
  ],
  dependencyDashboard: false,
  enabledManagers: [
    "npm",
    "bun",
    "github-actions",
    "dockerfile"
  ],
  packageRules: [
    {
      matchUpdateTypes: [
        "minor",
        "patch",
        "digest"
      ],
      groupName: "all minor, patch, and digest updates",
      groupSlug: "all-minor-patch-digest-updates",
      addLabels: [
        "automerge"
      ]
    },
    {
      matchManagers: [
        "npm",
        "bun"
      ],
      matchFileNames: [
        "apps/**",
        "packages/**",
        "package.json"
      ],
      groupName: "JavaScript/TypeScript dependencies"
    }
  ]
}
