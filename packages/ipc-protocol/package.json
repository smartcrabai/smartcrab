{
  "name": "@smartcrab/ipc-protocol",
  "version": "0.1.0",
  "type": "module",
  "description": "Single source of truth for JSON-RPC types and adapter interfaces shared between Bun service and SwiftUI",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./jsonrpc": "./src/jsonrpc.ts",
    "./methods": "./src/methods.ts",
    "./adapters": "./src/adapters.ts"
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "gen:jsonschema": "bun run scripts/gen-jsonschema.ts",
    "gen:swift": "bun run scripts/gen-swift.ts",
    "gen": "bun run gen:jsonschema && bun run gen:swift"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^6.0.0"
  }
}
